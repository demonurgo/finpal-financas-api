# Banco de dados
# `DATABASE_URL` e usada pela aplicacao quando ela roda localmente.
# O valor padrao aponta para o servico PostgreSQL do Docker Compose exposto em localhost:5433.
# Os dados do PostgreSQL ficam no volume nomeado `projeto-nassau_postgres_data`.
# `docker compose down` preserva esse volume. `docker compose down -v` remove esse volume.
POSTGRES_DB="finpal"
POSTGRES_USER="finpal"
POSTGRES_PASSWORD="finpal123"
POSTGRES_PORT=5433
DATABASE_URL="postgresql://finpal:finpal123@localhost:5433/finpal?schema=public"
DATABASE_URL_DOCKER="postgresql://finpal:finpal123@postgres:5432/finpal?schema=public"

# JWT
JWT_SECRET="change-me-in-production"
JWT_EXPIRES_IN="1d"

# Aplicacao
APP_PORT=3000
PORT=3000
NODE_ENV=development
# Cria o usuario demo e transacoes de exemplo quando `prisma db seed` for executado.
SEED_SAMPLE_DATA=true
